# Copy this file to .env.deploy and fill in your real Hostinger SSH values.

DEPLOY_HOST=your-hostinger-hostname
DEPLOY_USER=your-hostinger-ssh-user
DEPLOY_PORT=22
DEPLOY_APP_DIR=/home/your-user/nodejs

# Optional: uncomment if you use a custom SSH key.
# SSH_KEY_PATH=/home/you/.ssh/id_ed25519

# Optional: override if Hostinger needs a different install command.
# REMOTE_INSTALL_COMMAND=npm install --omit=dev

# Optional: set this if you know the remote restart command.
# REMOTE_RESTART_COMMAND=touch tmp/restart.txt
